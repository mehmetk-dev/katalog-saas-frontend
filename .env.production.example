# Environment variables for production deployment
# Copy this file to .env.local and fill in the values

# ============================================
# SUPABASE (Required)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# APPLICATION URLs
# ============================================
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Optional GA4 measurement ID. Example: G-XXXXXXXXXX
# NEXT_PUBLIC_GA_ID=
API_URL=https://api.your-domain.com/api/v1
# Optional browser-visible backend URL. If omitted, PDF export client uses the Next.js /api proxy.
# NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1

# ============================================
# ADMIN
# ============================================
ADMIN_EMAIL=admin@your-domain.com

# ============================================
# SECURITY (Backend)
# ============================================
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com 
PUBLIC_API_URL=https://api.your-domain.com/api/v1

# ============================================
# OPTIONAL - Caching
# ============================================
# REDIS_URL=redis://username:password@host:port

# ============================================
# OPTIONAL - PDF Export Worker
# ============================================
# PDF_EXPORT_RENDER_ORIGIN=https://your-domain.com
# WORKER_EXPORT_SECRET=replace-with-a-long-random-secret
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET=fogcatalog-pdf-exports
# R2_PDF_EXPORT_PREFIX=pdf-exports

# ============================================
# OPTIONAL - Analytics & Monitoring
# ============================================
# SENTRY_DSN=https://your-sentry-dsn
# VERCEL_ANALYTICS_ID=your-analytics-id
