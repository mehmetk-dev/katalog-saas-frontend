# -----------------------------------------------------------------------------
# BACKEND CONFIGURATION (.env)
# -----------------------------------------------------------------------------

# Server Port
PORT=4000

# Supabase Configuration
# [DİKKAT] Service Role Key gizli tutulmalıdır!
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage Provider (e.g., cloudinary, local)
STORAGE_PROVIDER=cloudinary
NEXT_PUBLIC_STORAGE_PROVIDER=cloudinary

# Cloudinary Configuration
# Ürün görsellerinin yönetimi ve silinenlerin arşivlenmesi için gereklidir.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_DELETED_FOLDER=deletedproducts

# SMTP Configuration (Zoho Mail)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=your_zoho_email
SMTP_PASS=your_zoho_app_password
SMTP_FROM=FogCatalog <your_zoho_email>

# Optional Redis Caching / PDF Export Queue
# REDIS_URL=redis://localhost:6379

# Server-side PDF export
PDF_EXPORT_RENDER_ORIGIN=http://localhost:3000
WORKER_EXPORT_SECRET=replace-with-a-long-random-secret
PDF_EXPORT_WORKER_CONCURRENCY=1
PDF_EXPORT_CLEANUP_INTERVAL_MS=3600000

# Cloudflare R2 (S3-compatible) storage for PDF exports
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=fogcatalog-pdf-exports
# Optional - defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# R2_ENDPOINT=
# Optional - object key prefix inside the bucket
# R2_PDF_EXPORT_PREFIX=pdf-exports

# Monitoring
# SENTRY_DSN=your_sentry_dsn
